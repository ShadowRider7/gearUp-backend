
model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  password     String
  phone        String?
  address      String?
  profileImage String?

  role   UserRole @default(CUSTOMER)
  status UserStatus @default(ACTIVE)

  providerGear    GearItem[]     @relation("ProviderGear")
  customerOrders  RentalOrder[]  @relation("CustomerOrders")
  providerOrders  RentalOrder[]  @relation("ProviderOrders")
  reviews         Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}