model User {
  id       String @id @default(uuid())
  name     String @db.VarChar(255)
  email    String @unique @db.VarChar(255)
  password String

  role   UserRole
  status UserStatus @default(ACTIVE)

  profile Profile?

  gearItems GearItem[]
  rentals  RentalOrder[]
  reviews  Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}