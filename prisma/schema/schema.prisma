// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  password     String
  phone        String?
  address      String?
  profileImage String?

  role   UserRole
  status UserStatus @default(ACTIVE)

  providerGear    GearItem[]     @relation("ProviderGear")
  customerOrders  RentalOrder[]  @relation("CustomerOrders")
  providerOrders  RentalOrder[]  @relation("ProviderOrders")
  reviews         Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String @id @default(uuid())
  name        String @unique
  description String?

  gearItems GearItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GearItem {
  id          String  @id @default(uuid())
  name        String
  description String
  brand       String

  pricePerDay Float
  stock       Int

  images String[]

  specifications Json?

  isAvailable Boolean @default(true)

  categoryId String
  providerId String

  category Category @relation(fields: [categoryId], references: [id])

  provider User @relation(
    "ProviderGear",
    fields: [providerId],
    references: [id]
  )

  rentalItems RentalItem[]

  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RentalOrder {
  id String @id @default(uuid())

  customerId String
  providerId String

  startDate DateTime
  endDate   DateTime

  totalAmount Float

  status RentalStatus @default(PLACED)

  customer User @relation(
    "CustomerOrders",
    fields: [customerId],
    references: [id]
  )

  provider User @relation(
    "ProviderOrders",
    fields: [providerId],
    references: [id]
  )

  rentalItems RentalItem[]

  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RentalItem {
  id String @id @default(uuid())

  rentalOrderId String
  gearItemId     String

  quantity Int

  pricePerDay Float

  subtotal Float

  rentalOrder RentalOrder @relation(
    fields: [rentalOrderId],
    references: [id]
  )

  gearItem GearItem @relation(
    fields: [gearItemId],
    references: [id]
  )
}

model Payment {
  id String @id @default(uuid())

  rentalOrderId String @unique

  transactionId String @unique

  amount Float

  method PaymentMethod

  status PaymentStatus @default(PENDING)

  paidAt DateTime?

  rentalOrder RentalOrder @relation(
    fields: [rentalOrderId],
    references: [id]
  )

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id String @id @default(uuid())

  customerId String

  gearItemId String

  rating Int

  comment String?

  customer User @relation(
    fields: [customerId],
    references: [id]
  )

  gearItem GearItem @relation(
    fields: [gearItemId],
    references: [id]
  )

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerId, gearItemId])
}